import logging
import numpy as np
from .base import BaseStrategy

logger = logging.getLogger(__name__)

class BreakoutStrategy(BaseStrategy):
    """
    Keltner Channels breakout with volume confirmation.
    - Long when price breaks above upper channel with volume > 1.2x average.
    - Short when price breaks below lower channel with volume > 1.2x average.
    """
    def __init__(self, period: int = 20, atr_mult: float = 1.5, volume_ratio: float = 1.2):
        super().__init__("Breakout")
        self.period = period
        self.atr_mult = atr_mult
        self.volume_ratio = volume_ratio

    def calculate_signal(self, data: dict) -> tuple:
        candles = data.get("1h", {}).get("candles")
        if not candles or len(candles) < self.period + 1:
            logger.warning(f"{self.name}: insufficient candle data")
            return "HOLD", 0

        high = np.array([c[2] for c in candles])
        low = np.array([c[3] for c in candles])
        close = np.array([c[4] for c in candles])
        volume = np.array([c[5] for c in candles])

        # Middle line = EMA of close
        ema = self._ema(close, self.period)
        # ATR-based channel
        tr = np.maximum(high[1:] - low[1:],
                        np.maximum(abs(high[1:] - close[:-1]),
                                   abs(low[1:] - close[:-1])))
        atr = np.mean(tr[-self.period:])
        upper = ema[-1] + self.atr_mult * atr
        lower = ema[-1] - self.atr_mult * atr

        avg_volume = np.mean(volume[-self.period:])
        current_price = close[-1]
        current_vol = volume[-1]

        if current_price > upper and current_vol > avg_volume * self.volume_ratio:
            confidence = int(60 + (current_price - upper) / atr * 20)
            return "BUY", min(100, confidence)
        elif current_price < lower and current_vol > avg_volume * self.volume_ratio:
            confidence = int(60 + (lower - current_price) / atr * 20)
            return "SELL", min(100, confidence)
        return "HOLD", 0

    @staticmethod
    def _ema(values, period):
        alpha = 2 / (period + 1)
        ema = [values[0]]
        for v in values[1:]:
            ema.append(alpha * v + (1 - alpha) * ema[-1])
        return np.array(ema)
